{
  "mcpServers": {
    "filesystem": {
      "command": "npx",
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "/home/reggie/vscode_folder/Enterprise-grade_RAG",
        "/home/reggie/vscode_folder/MCP"
      ]
    },
    "git": {
      "command": "docker",
      "args": [
        "run",
        "--rm",
        "-i",
        "--mount",
        "type=bind,src=/home/reggie/vscode_folder/Enterprise-grade_RAG,dst=/workspace/repo",
        "mcp/git",
        "-r",
        "/workspace/repo"
      ]
    },
    "codegraph": {
      "command": "node",
      "args": [
        "/home/reggie/vscode_folder/MCP/mcp-server-codegraph/dist/index.js",
        "/home/reggie/vscode_folder/Enterprise-grade_RAG"
      ],
      "cwd": "/home/reggie/vscode_folder/MCP/mcp-server-codegraph"
    },
    "4_5v_mcp": {
      "command": "/home/reggie/vscode_folder/Enterprise-grade_RAG/.codex/bin/run-streamable-http-mcp.sh"
    },
    "next-ai-draw-io": {
      "command": "/home/reggie/vscode_folder/Enterprise-grade_RAG/.codex/bin/run-next-ai-drawio-mcp.sh"
    },
    "qdrant": {
      "command": "/home/reggie/vscode_folder/Enterprise-grade_RAG/.codex/bin/run-qdrant-mcp.sh"
    },
    "github": {
      "type": "http",
      "url": "https://api.githubcopilot.com/mcp/",
      "headers": {
        "Authorization": "Bearer ${GITHUB_PAT_TOKEN}"
      }
    }
  }
}
