RAG_APP_NAME=Enterprise-grade RAG API
RAG_APP_ENV=development
RAG_DEBUG=true
RAG_API_V1_PREFIX=/api/v1
RAG_CORS_ORIGINS=["*"]

# Local development mode:
# API / worker run on local machine by default; upload assets and metadata use server PostgreSQL.
RAG_QDRANT_URL=http://192.168.10.200:6333
RAG_QDRANT_COLLECTION=enterprise_rag_v1_local_bge_m3
RAG_ASSET_STORE_BACKEND=filesystem
RAG_POSTGRES_METADATA_ENABLED=true
RAG_POSTGRES_METADATA_DSN=postgresql://root:123456@192.168.10.200:5432/welllihaidb?schema=public
DATABASE_URL=postgresql://root:123456@192.168.10.200:5432/welllihaidb?schema=public
RAG_CELERY_BROKER_URL=redis://192.168.10.200:6379/0
RAG_CELERY_RESULT_BACKEND=redis://192.168.10.200:6379/1
RAG_CELERY_INGEST_QUEUE=ingest
RAG_CELERY_TASK_ALWAYS_EAGER=false
RAG_CELERY_TASK_EAGER_PROPAGATES=true

RAG_LLM_PROVIDER=openai
RAG_LLM_BASE_URL=http://192.168.10.200:8000/v1
RAG_LLM_API_KEY=
RAG_LLM_MODEL=Qwen2.5-14B-Instruct
RAG_LLM_TIMEOUT_SECONDS=180
RAG_LLM_TEMPERATURE=0.1

RAG_EMBEDDING_PROVIDER=openai
RAG_EMBEDDING_BASE_URL=http://192.168.10.200:8002/v1
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_RERANKER_PROVIDER=heuristic
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_EMBEDDING_TIMEOUT_SECONDS=120
RAG_EMBEDDING_BATCH_SIZE=16
RAG_EMBEDDING_MOCK_VECTOR_SIZE=32

RAG_TOP_K_DEFAULT=5
RAG_RERANK_TOP_N=3
RAG_CHUNK_SIZE_CHARS=800
RAG_CHUNK_OVERLAP_CHARS=120
RAG_CHUNK_MIN_CHARS=200
RAG_UPLOAD_MAX_FILE_SIZE_BYTES=104857600
