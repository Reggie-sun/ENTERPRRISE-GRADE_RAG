// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema
//
// ═══════════════════════════════════════════════════════════
// 双数据库架构说明
// ───────────────────────────────────────────────────────────
// ① PostgreSQL (此文件管理) — AI 自身元数据 + Enterprise-grade_RAG 元数据
//      · Message               历史对话记录
//      · KnowledgeDocument     旧版知识库向量文档 (pgvector, legacy)
//      · PromptTemplate        认知改造 System Prompt 模板
//      · AiSession             会话身份映射（对应 MySQL 业务用户 ID）
//      · RagSourceDocument     Enterprise-grade_RAG 文档主数据
//      · RagDocumentVersion    Enterprise-grade_RAG 文档版本
//      · RagIngestJob          Enterprise-grade_RAG 入库任务
//      · RagKnowledgeChunk     Enterprise-grade_RAG 向量 chunk（pgvector, bge-m3）
//
// ② MySQL (mysql2 连接池，见 src/database/) — 业务数据
//      · 只读查询，供 AI Tool Calling 检索业务数据
//      · 不由 Prisma 管理，表结构以实际业务库为准
// ═══════════════════════════════════════════════════════════

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
  output          = "../node_modules/.prisma/client"
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [pgvector(map: "vector")]
}

// ─────────────────────────────────────────────────────────
// 会话表（绑定 MySQL 业务用户 ID，不存密码）
// userId 来自业务 MySQL，此处仅做字符串引用
// ─────────────────────────────────────────────────────────
model AiSession {
  id        String   @id @default(uuid())
  /// 对应 MySQL 业务库中的用户主键（字符串化）
  userId    String
  /// 会话标题（可选，前端展示用）
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  messages  Message[]

  @@index([userId])
  @@map("ai_sessions")
}

// ─────────────────────────────────────────────────────────
// 历史对话记录表
// ─────────────────────────────────────────────────────────
model Message {
  id          String      @id @default(uuid())
  /// 关联的 AI 会话
  sessionId   String
  /// 对话轮次唯一标识（一次 processChat 调用内所有消息共享同一 turnId）
  turnId      String?
  role        MessageRole /// "user" | "assistant" | "tool"
  content     String      @db.Text
  /// Tool Calling 时存放工具名称
  toolName    String?
  /// Tool Calling 时仅存放 LangChain 原生协议对象：
  ///   assistant 角色: { tool_calls: [...] }
  ///   tool 角色:      { name, tool_call_id }
  /// 严禁将业务状态（如 turnId、taskId 等）混入此字段
  toolPayload Json?
  createdAt   DateTime    @default(now())

  session AiSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@map("messages")
}

enum MessageRole {
  user
  assistant
  tool
}

// ─────────────────────────────────────────────────────────
// 知识库文档记录表 (RAG, legacy)
// pgvector 向量字段使用 Unsupported("vector(1536)")
// 1536 对应 OpenAI text-embedding-ada-002 维度
// 如使用其他模型请修改维度值
// ─────────────────────────────────────────────────────────
//
// 注意：
// 这张表按你的要求保持原结构不动。
// 当前 Enterprise-grade_RAG 项目实际使用 BAAI/bge-m3，维度 1024，
// 因此新增的向量表使用 RagKnowledgeChunk，而不是直接复用本表。
model KnowledgeDocument {
  id         String   @id @default(uuid())
  /// 来源文件名
  filename   String
  /// 文档所属分类/命名空间，方便按业务场景过滤
  namespace  String   @default("default")
  /// 文档切分后的文本片段内容
  content    String   @db.Text
  /// 向量字段 (pgvector)，维度由 EMBEDDING_DIMENSION 环境变量决定
  /// Prisma 通过 Unsupported 透传原生类型，迁移时会生成对应 DDL
  embedding  Unsupported("vector(1536)")?
  /// 原始元数据，如页码、章节等
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([namespace])
  @@map("knowledge_documents")
}

// ─────────────────────────────────────────────────────────
// 认知改造系统提示词模板表
// ─────────────────────────────────────────────────────────
model PromptTemplate {
  id          String   @id @default(uuid())
  /// 模板唯一标识 key，代码中通过 key 加载
  key         String   @unique
  /// 模板名称（人类可读）
  name        String
  /// 完整的 System Prompt 内容，支持 {{variable}} 插值占位符
  content     String   @db.Text
  /// Few-Shot 示例，JSON 数组格式: [{role, content}, ...]
  fewShots    Json?
  /// 适用场景描述
  description String?
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("prompt_templates")
}

// ─────────────────────────────────────────────────────────
// Enterprise-grade_RAG 新增表
// 不改 legacy 表结构，只为当前项目补齐文档、任务和 1024 维向量存储
// ─────────────────────────────────────────────────────────

enum RagVisibility {
  public
  department
  role
  private
}

enum RagClassification {
  public
  internal
  confidential
  secret
}

enum RagDocumentStatus {
  queued
  uploaded
  active
  failed
  partial_failed
}

enum RagIngestJobStatus {
  pending
  uploaded
  queued
  parsing
  ocr_processing
  chunking
  embedding
  indexing
  completed
  failed
  dead_letter
  partial_failed
}

// 文档主表：对应当前项目里的 DocumentRecord
model RagSourceDocument {
  id             String            @id @default(uuid())
  docId          String            @unique
  tenantId       String
  fileName       String
  fileHash       String
  sourceType     String
  sourceSystem   String?
  createdBy      String?
  ownerId        String?
  visibility     RagVisibility     @default(private)
  classification RagClassification @default(internal)
  departmentIds  String[]          @default([])
  roleIds        String[]          @default([])
  tags           String[]          @default([])
  namespace      String            @default("default")
  status         RagDocumentStatus @default(queued)
  currentVersion Int               @default(1)
  latestJobId    String?
  storagePath    String
  metadata       Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  versions       RagDocumentVersion[]
  jobs           RagIngestJob[]
  chunks         RagKnowledgeChunk[]
  assets         RagDataAsset[]

  @@index([tenantId])
  @@index([fileHash])
  @@index([namespace])
  @@index([status])
  @@map("rag_source_documents")
}

// 文档版本表：为后续重跑、回滚、切版本预留
model RagDocumentVersion {
  id           String            @id @default(uuid())
  docId        String
  version      Int
  storagePath  String
  parsedPath   String?
  chunkPath    String?
  chunkCount   Int               @default(0)
  vectorCount  Int               @default(0)
  indexVersion Int?
  isCurrent    Boolean           @default(true)
  status       RagDocumentStatus @default(active)
  metadata     Json?
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  document     RagSourceDocument @relation(fields: [docId], references: [docId], onDelete: Cascade)

  @@unique([docId, version])
  @@index([docId])
  @@index([isCurrent])
  @@map("rag_document_versions")
}

// 入库任务表：对应当前项目里的 IngestJobRecord
model RagIngestJob {
  id           String           @id @default(uuid())
  jobId        String           @unique
  docId        String
  version      Int              @default(1)
  fileName     String
  status       RagIngestJobStatus @default(queued)
  stage        String           @default("queued")
  progress     Int              @default(0)
  retryCount   Int              @default(0)
  errorCode    String?
  errorMessage String?
  metadata     Json?
  createdAt    DateTime         @default(now())
  updatedAt    DateTime         @updatedAt

  document     RagSourceDocument @relation(fields: [docId], references: [docId], onDelete: Cascade)
  assets       RagDataAsset[]

  @@index([docId])
  @@index([status])
  @@index([createdAt])
  @@map("rag_ingest_jobs")
}

// 当前项目真正使用的向量 chunk 表
// 与 legacy KnowledgeDocument 分离，原因是当前 embedding 模型为 bge-m3，维度为 1024
model RagKnowledgeChunk {
  id             String            @id @default(uuid())
  chunkId        String            @unique
  docId          String
  version        Int               @default(1)
  tenantId       String
  namespace      String            @default("default")
  chunkIndex     Int
  content        String            @db.Text
  embeddingModel String            @default("BAAI/bge-m3")
  embedding      Unsupported("vector(1024)")?
  sourcePath     String?
  parsedPath     String?
  charStart      Int?
  charEnd        Int?
  pageNo         Int?
  ownerId        String?
  visibility     RagVisibility     @default(private)
  classification RagClassification @default(internal)
  departmentIds  String[]          @default([])
  roleIds        String[]          @default([])
  metadata       Json?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt

  document       RagSourceDocument @relation(fields: [docId], references: [docId], onDelete: Cascade)

  @@index([docId])
  @@index([tenantId])
  @@index([namespace])
  @@index([embeddingModel])
  @@index([createdAt])
  @@map("rag_knowledge_chunks")
}

// data/ 目录完整镜像表
// 用于把 uploads / parsed / chunks / documents / jobs 全部放入 PostgreSQL
model RagDataAsset {
  id           String             @id @default(uuid())
  assetKey     String             @unique
  docId        String?
  jobId        String?
  kind         String
  relativePath String
  fileName     String
  mimeType     String?
  sizeBytes    Int
  sha256       String
  textContent  String?            @db.Text
  binaryContent Bytes?
  metadata     Json?
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt

  document     RagSourceDocument? @relation(fields: [docId], references: [docId], onDelete: SetNull)
  job          RagIngestJob?      @relation(fields: [jobId], references: [jobId], onDelete: SetNull)

  @@index([docId])
  @@index([jobId])
  @@index([kind])
  @@index([relativePath])
  @@map("rag_data_assets")
}

// 注意：
// 1. Prisma 只能声明 vector 列，ivfflat/hnsw 索引仍需在 SQL migration 里补。
// 2. 示例：
//    CREATE EXTENSION IF NOT EXISTS vector;
//    CREATE INDEX rag_knowledge_chunks_embedding_hnsw_idx
//    ON rag_knowledge_chunks
//    USING hnsw (embedding vector_cosine_ops);
