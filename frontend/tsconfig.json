{
  "compilerOptions": {
    "target": "ES2020",  // 编译目标为 ES2020。
    "useDefineForClassFields": true,  // 使用标准的类字段定义语义。
    "lib": ["ES2020", "DOM", "DOM.Iterable"],  // 包含的库类型声明。
    "module": "ESNext",  // 使用最新的 ES 模块系统。
    "skipLibCheck": true,  // 跳过库文件的类型检查，加快编译速度。

    /* Bundler mode */
    "moduleResolution": "bundler",  // 使用 bundler 模式的模块解析策略。
    "allowImportingTsExtensions": true,  // 允许导入 .ts 扩展名的文件。
    "isolatedModules": true,  // 确保每个文件都可以单独编译。
    "moduleDetection": "force",  // 强制模块检测。
    "noEmit": true,  // 不生成输出文件，由 Vite 负责打包。
    "jsx": "react-jsx",  // 使用 React 17+ 的 JSX 转换。

    /* Linting */
    "strict": true,  // 启用严格模式。
    "noUnusedLocals": true,  // 禁止未使用的局部变量。
    "noUnusedParameters": true,  // 禁止未使用的参数。
    "noFallthroughCasesInSwitch": true,  // 禁止 switch 语句的 fallthrough。

    /* Paths */
    "baseUrl": ".",  // 设置基础路径。
    "paths": {
      "@/*": ["src/*"]  // 配置路径别名，@/ 指向 src/ 目录。
    }
  },
  "include": ["src"]  // 包含 src 目录下的所有文件。
}