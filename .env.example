RAG_APP_NAME=Enterprise-grade RAG API
RAG_APP_ENV=development
RAG_DEBUG=true
RAG_API_V1_PREFIX=/api/v1
RAG_CORS_ORIGINS=["*"]

RAG_QDRANT_URL=http://qdrant:6333
RAG_QDRANT_COLLECTION=enterprise_rag_v1
RAG_CELERY_BROKER_URL=redis://redis:6379/0
RAG_CELERY_RESULT_BACKEND=redis://redis:6379/1
RAG_CELERY_INGEST_QUEUE=ingest
RAG_CELERY_TASK_ALWAYS_EAGER=false
RAG_CELERY_TASK_EAGER_PROPAGATES=true

# Point this to your remote model server.
## Supported values: mock, ollama
RAG_LLM_PROVIDER=mock
RAG_OLLAMA_BASE_URL=http://your-llm-server:11434
RAG_OLLAMA_MODEL=qwen2.5:7b
RAG_LLM_TIMEOUT_SECONDS=180
RAG_LLM_TEMPERATURE=0.1

## Supported values: ollama, openai, mock
RAG_EMBEDDING_PROVIDER=ollama
# If empty, the backend will reuse RAG_OLLAMA_BASE_URL.
RAG_EMBEDDING_BASE_URL=http://your-embedding-server:11434
RAG_EMBEDDING_API_KEY=
RAG_EMBEDDING_MODEL=BAAI/bge-m3
RAG_RERANKER_PROVIDER=heuristic
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3
RAG_EMBEDDING_TIMEOUT_SECONDS=120
RAG_EMBEDDING_BATCH_SIZE=16
RAG_EMBEDDING_MOCK_VECTOR_SIZE=32

RAG_TOP_K_DEFAULT=5
RAG_RERANK_TOP_N=3
RAG_CHUNK_SIZE_CHARS=800
RAG_CHUNK_OVERLAP_CHARS=120
RAG_CHUNK_MIN_CHARS=200
