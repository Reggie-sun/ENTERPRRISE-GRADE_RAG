# ============================================================
# 应用基础配置 / Application Basic Configuration
# Verified local development baseline:
# frontend / API / worker run on host:3000/8020, infra services run on a remote server.
# 当前已验证的本地开发基线：
# 前端 / API / worker 跑在本机 3000/8020，基础设施服务跑在远端服务器。
# ============================================================
RAG_APP_NAME=Enterprise-grade RAG API  # 应用名称 / Application name
RAG_APP_ENV=development  # 运行环境：development / test / production / Environment
RAG_DEBUG=true  # 是否开启调试模式 / Enable debug mode
RAG_API_V1_PREFIX=/api/v1  # API v1 路由前缀 / API v1 route prefix
RAG_CORS_ORIGINS=["*"]  # 允许跨域的来源列表 / Allowed CORS origins

# ============================================================
# 向量数据库配置 / Vector Store Configuration
# ============================================================
RAG_QDRANT_URL=http://your-rag-server:6333  # Qdrant 服务地址 / Qdrant service URL
RAG_QDRANT_COLLECTION=enterprise_rag_v1  # Qdrant collection 名称 / Collection name

# ============================================================
# PostgreSQL 元数据存储 / PostgreSQL Metadata Store
# Enable this to persist document/job metadata into PostgreSQL.
# 启用后 document/job 元数据会写入 PostgreSQL（当前检索仍可继续用 Qdrant）。
# ============================================================
RAG_POSTGRES_METADATA_ENABLED=false  # 是否启用 PostgreSQL 元数据真源 / Enable PostgreSQL metadata source
RAG_POSTGRES_METADATA_DSN=  # PostgreSQL 连接串，未配置时后端会回退读 DATABASE_URL / PostgreSQL DSN
DATABASE_URL=  # 可选 Prisma 兼容连接串；未配置 RAG_POSTGRES_METADATA_DSN 时作为回退 / Optional Prisma-compatible DSN fallback

# ============================================================
# Celery 队列配置 / Celery Queue Configuration
# ============================================================
RAG_CELERY_BROKER_URL=redis://your-rag-server:6379/0  # Celery broker 地址 / Broker URL
RAG_CELERY_RESULT_BACKEND=redis://your-rag-server:6379/1  # Celery 结果后端 / Result backend URL
RAG_CELERY_INGEST_QUEUE=ingest  # 入库任务队列名称 / Ingest queue name
RAG_CELERY_TASK_ALWAYS_EAGER=false  # eager 模式：任务在当前进程直接执行 / Eager mode
RAG_CELERY_TASK_EAGER_PROPAGATES=true  # eager 模式下异常直接抛出 / Propagate exceptions in eager mode
RAG_INGEST_FAILURE_RETRY_LIMIT=3  # 入库失败进入 dead_letter 前的最大失败次数 / Retry limit
RAG_INGEST_RETRY_DELAY_SECONDS=2  # Celery 自动重试间隔（秒）/ Retry delay seconds

# ============================================================
# LLM 生成模型配置 / LLM Generation Configuration
# Point this to your local or remote model server.
# 指向本地或远程模型服务。
# Supported values: mock, ollama, openai / 支持的值
# ============================================================
RAG_LLM_PROVIDER=openai  # LLM 提供方类型 / LLM provider type
RAG_LLM_BASE_URL=http://your-rag-server:8000/v1  # LLM 服务地址 / LLM service URL
RAG_LLM_API_KEY=  # LLM API 密钥（本地 vLLM 可留空）/ API key (empty for local vLLM)
RAG_LLM_MODEL=Qwen/Qwen2.5-7B-Instruct  # LLM 模型名称 / Model name
RAG_OLLAMA_BASE_URL=http://127.0.0.1:11434  # Ollama 服务地址（兼容旧配置）/ Ollama URL
RAG_OLLAMA_MODEL=qwen2.5:7b  # Ollama 模型名称（兼容旧配置）/ Ollama model
RAG_LLM_TIMEOUT_SECONDS=180  # LLM 请求超时秒数 / Request timeout
RAG_LLM_TEMPERATURE=0.1  # LLM 采样温度 / Sampling temperature
RAG_LLM_MAX_PROMPT_TOKENS=2200  # prompt 软预算，避免大上下文把回答 token 挤光 / Prompt soft budget
RAG_LLM_RESERVED_COMPLETION_TOKENS=512  # 给回答保留的 token 数 / Reserved completion tokens
RAG_TOKENIZER_PROVIDER=heuristic  # token 预算服务 provider：heuristic / transformers_auto
RAG_TOKENIZER_MODEL=  # 可选 tokenizer 模型名；为空时回退到当前 llm model
RAG_TOKENIZER_TRUST_REMOTE_CODE=false  # 是否允许 AutoTokenizer 加载 remote code
RAG_CHAT_MEMORY_ENABLED=true  # 是否启用轻记忆 / Enable lightweight multi-turn memory
RAG_CHAT_MEMORY_MAX_TURNS=6  # 最近几轮会话保留上限 / Max recent turns kept in memory
RAG_CHAT_MEMORY_MAX_PROMPT_TOKENS=360  # 注入 prompt 的轻记忆预算 / Prompt budget reserved for lightweight memory
RAG_CHAT_MEMORY_QUESTION_MAX_CHARS=200  # 单轮问题进入轻记忆时的最大字符数 / Max chars per remembered question
RAG_CHAT_MEMORY_ANSWER_MAX_CHARS=400  # 单轮回答进入轻记忆时的最大字符数 / Max chars per remembered answer
RAG_QUERY_REWRITE_ENABLED=true  # 是否启用最小追问改写 / Enable lightweight follow-up query rewrite
RAG_QUERY_REWRITE_SHORT_QUESTION_MAX_CHARS=18  # 仅短追问进入改写 / Max chars for rewrite-eligible short questions
RAG_DEPARTMENT_QUERY_ISOLATION_ENABLED=true  # 是否启用部门读隔离；关闭后只放开检索/问答/阅读，不放开写入边界 / Department read isolation toggle

# ============================================================
# Embedding 向量化配置 / Embedding Configuration
# Supported values: ollama, openai, mock / 支持的值
# ============================================================
RAG_EMBEDDING_PROVIDER=openai  # Embedding 提供方类型 / Embedding provider type
# If empty, the backend will reuse RAG_OLLAMA_BASE_URL.
# 如果为空，后端将复用 RAG_OLLAMA_BASE_URL。
RAG_EMBEDDING_BASE_URL=http://your-rag-server:8002/v1  # Embedding 服务地址 / Embedding service URL
RAG_EMBEDDING_API_KEY=  # Embedding API 密钥 / API key
RAG_EMBEDDING_MODEL=BAAI/bge-m3  # Embedding 模型名称 / Model name
RAG_RERANKER_PROVIDER=heuristic  # Reranker 提供方类型 / Reranker provider type
RAG_RERANKER_BASE_URL=  # 独立 Reranker 服务地址；为空时按 embedding/llm 地址回退 / Dedicated reranker URL, falls back to embedding/llm URL
RAG_RERANKER_API_KEY=  # Reranker API 密钥（本地无鉴权服务可留空）/ Reranker API key
RAG_RERANKER_MODEL=BAAI/bge-reranker-v2-m3  # Reranker 模型名称 / Reranker model name
RAG_RERANKER_TIMEOUT_SECONDS=12  # Reranker 请求超时秒数 / Request timeout
RAG_EMBEDDING_TIMEOUT_SECONDS=120  # Embedding 请求超时秒数 / Request timeout
RAG_EMBEDDING_BATCH_SIZE=16  # Embedding 批处理大小 / Batch size
RAG_EMBEDDING_MOCK_VECTOR_SIZE=32  # Mock 模式下的向量维度 / Mock vector dimension

# ============================================================
# 文档处理配置 / Document Processing Configuration
# ============================================================
RAG_TOP_K_DEFAULT=5  # 默认检索返回数量 / Default retrieval top-k
RAG_RERANK_TOP_N=3  # Rerank 后保留数量 / Rerank top-n
RAG_CHUNK_SIZE_CHARS=400  # 每个块的目标字符数 / Target chunk size
RAG_CHUNK_OVERLAP_CHARS=120  # 相邻块的重叠字符数 / Chunk overlap
RAG_CHUNK_MIN_CHARS=200  # 块的最小字符数阈值 / Minimum chunk size
RAG_UPLOAD_MAX_FILE_SIZE_BYTES=104857600  # 上传文件大小上限（默认 100MB）/ Max upload size
RAG_DATA_ASSET_STORE_BINARY_ENABLED=true  # 是否写入 data 资产 binaryContent（建议生产环境评估关闭）/ Store binary content for data assets
RAG_DATA_ASSET_BINARY_MAX_BYTES=1048576  # 单文件二进制落库大小上限（默认 1MB）/ Max bytes to store in binaryContent

# ============================================================
# OCR 配置 / OCR Configuration
# Install one OCR requirements file before enabling paddleocr.
# 启用 paddleocr 前先安装 requirements/ocr-cpu.txt 或 requirements/ocr-gpu-cu130.txt。
# ============================================================
RAG_OCR_PROVIDER=disabled  # OCR provider: disabled / mock / paddleocr
RAG_OCR_LANGUAGE=ch  # OCR language code
RAG_OCR_PDF_NATIVE_TEXT_MIN_CHARS=80  # PDF 原生文本低于该阈值时尝试 OCR fallback
RAG_OCR_PADDLE_USE_ANGLE_CLS=false  # PaddleOCR 3.x 默认关闭 angle cls，避免和 textline_orientation 互斥
