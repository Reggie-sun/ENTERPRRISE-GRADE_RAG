  "field_definitions": {
    "id": "评测样本唯一标识，格式 eval_NNN",
    "type": "样本类型：alarm_code | concept_explanation | process_steps | comparison | metric | department_private | global_knowledge | refuse_or_empty",
    "query": "检索查询文本",
    "expected_document_ids": "期望命中的文档 ID 列表。空数组表示文档库中不应存在相关文档",
    "scope_expectation": "访问范围预期：global（所有部门可访问）| department（仅指定部门可访问）",
    "accessible_departments": "有权访问的部门 ID 列表（仅 scope_expectation=department 时需要）",
    "inaccessible_departments": "不应有权访问的部门 ID 列表（用于权限回归验证）",
    "should_refuse": "是否应被拒答（恶意/敏感查询）",
    "expected_top1_hit": "期望第一条结果就命中目标文档",
    "notes": "补充说明"
  }
}
